# Moonraker Agent Service - Environment Variables
# Copy to .env and fill in values

# ── LLM (for Browser Use agent tasks) ──────────────────────
ANTHROPIC_API_KEY=

# ── Surge Platform (entity + content audits) ───────────────
SURGE_URL=https://www.surgeaiprotocol.com
SURGE_EMAIL=
SURGE_PASSWORD=

# ── Client HQ Integration ──────────────────────────────────
CLIENT_HQ_URL=https://clients.moonraker.ai
AGENT_API_KEY=

# ── Supabase (direct DB access for status updates) ─────────
SUPABASE_URL=https://ofmmwcjhdrhvxxkhcuww.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email notifications) ───────────────────────────
RESEND_API_KEY=

# ── Google (Drive access for logos, service account JSON) ───
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Cloudflare R2 (via moonraker-r2-worker) — REQUIRED for site migration ──
# Worker URL with no trailing slash, e.g.
#   https://moonraker-r2-worker.<account>.workers.dev
R2_INGEST_URL=
# Shared bearer secret matching the Worker's R2_INGEST_SECRET binding.
R2_INGEST_SECRET=
# Sanity anchor — must equal "client-sites" (the only bucket the Worker
# is bound to). Module logs a warning if it differs.
R2_MIGRATION_BUCKET=client-sites

# ── Cloudflare Images (OPTIONAL) ───────────────────────────
# Site migration ships assets through R2 by default (the Cloudflare
# account is on the free Images tier, which does not include hosted
# images). Leave the three keys below blank to disable the integration —
# the agent will then store NULL for cf_image_id on every asset row and
# the rewriter will emit `<R2_INGEST_URL>/serve/<r2_key>` URLs.
#
# Re-enable later by setting all three together. The rewriter will then
# emit imagedelivery.net URLs for any asset that has a cf_image_id.
# CF_API_TOKEN=
# CF_ACCOUNT_ID=
# CF_IMAGES_HASH=

# ── WordPress credentials (per-client, passed in task payload) ──
# Not stored in .env — sent with each task request
